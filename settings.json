{
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "CLAUDE_CODE_SKIP_BEDROCK_AUTH": "1",
    "ANTHROPIC_BEDROCK_BASE_URL": "https://aigateway.instacart.tools/proxy/claude-code/bedrock/tag/local-claude/user/joshua.toyota@instacart.com",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://otlp.proxy.datadog.internal.pika.ac:4317",
    "OTEL_RESOURCE_ATTRIBUTES": "service.name=claude-code-cli,user.email=joshua.toyota@instacart.com",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "us.anthropic.claude-opus-4-6-v1",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_METRICS_INCLUDE_VERSION": "true",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "us.anthropic.claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "us.anthropic.claude-haiku-4-5-20251001-v1:0",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "NotebookRead",
      "AskUserQuestion",
      "Skill",
      "SlashCommand",
      "BashOutput",
      "KillShell",
      "mcp__playwright__*",
      "mcp__chrome-devtools__*",
      "mcp__glean__*",
      "mcp__glean_default__*",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Edit(~/.ssh/**)",
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(~/.isc/**)",
      "Read(~/.bento/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.npm/**)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/Library/Keychains/**)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(isc:*)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "~/work"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "PARENT_ARGS=$(ps -p $PPID -o args= 2>/dev/null); if ! echo \"$PARENT_ARGS\" | grep -q -- \"--team-name\"; then echo \"$TMUX_PANE\" > /tmp/claude_main_pane; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "PARENT_ARGS=$(ps -p $PPID -o args= 2>/dev/null); if ! echo \"$PARENT_ARGS\" | grep -q -- \"--team-name\"; then SAVED_PANE=$(cat /tmp/claude_main_pane 2>/dev/null); if [ -n \"$SAVED_PANE\" ]; then tmux select-pane -t \"$SAVED_PANE\"; fi; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'gh pr create' && (h pr track && h pr tag $(h pr number) $(h task current) $(h branch current) && h branch save) || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "MSG=$(cat | jq -r '.message // \"Needs input\"'); PARENT_ARGS=$(ps -p $PPID -o args= 2>/dev/null); if ! echo \"$PARENT_ARGS\" | grep -q -- \"--team-name\"; then h alert -t 'Claude Code' -m \"$MSG\" -s k -c \"echo switchc -t '$TMUX_PANE' | pbcopy\"; h notify push -t info \"$MSG\"; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PARENT_ARGS=$(ps -p $PPID -o args= 2>/dev/null); if ! echo \"$PARENT_ARGS\" | grep -q -- \"--team-name\"; then h alert -t 'Claude Code' -m 'Work completed' -s b -c \"echo switchc -t '$TMUX_PANE' | pbcopy\"; h notify push -t success 'Work completed'; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); current_time=$(date '+%Y-%m-%d %H:%M:%S'); if git -C \"$cwd\" rev-parse --git-dir > /dev/null 2>&1; then branch=$(git -C \"$cwd\" branch --show-current 2>/dev/null); staged=$(git -C \"$cwd\" diff --cached --name-only --no-optional-locks 2>/dev/null | wc -l | tr -d ' '); modified=$(git -C \"$cwd\" diff --name-only --no-optional-locks 2>/dev/null | wc -l | tr -d ' '); untracked=$(git -C \"$cwd\" ls-files --others --exclude-standard --no-optional-locks 2>/dev/null | wc -l | tr -d ' '); git_status=\"\"; if [ \"$staged\" -gt 0 ] || [ \"$modified\" -gt 0 ] || [ \"$untracked\" -gt 0 ]; then git_status=\" (\"; [ \"$staged\" -gt 0 ] && git_status=\"${git_status}${staged}\"; [ \"$modified\" -gt 0 ] && git_status=\"${git_status}${modified}\"; [ \"$untracked\" -gt 0 ] && git_status=\"${git_status}${untracked}\"; git_status=\"${git_status})\"; fi; git_info=\" ${branch}${git_status}\"; else git_info=\"\"; fi; printf \"%s %s%s\" \"$current_time\" \"$cwd\" \"$git_info\""
  },
