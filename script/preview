#!/usr/bin/env ruby

require 'fileutils'
require 'pathname'

REPO_ROOT = Pathname.new(File.expand_path('..', __dir__))
CLAUDE_HOME = Pathname.new(File.expand_path('~/.claude'))

# Files/folders to track (tooling)
TRACKED_PATTERNS = %w[
  commands
  agents
  skills
  settings.json
  settings.local.json
]

def main
  puts "=== Preview Mode (no changes will be made) ===\n\n"

  TRACKED_PATTERNS.each do |pattern|
    repo_path = REPO_ROOT / pattern
    home_path = CLAUDE_HOME / pattern

    is_dir = (repo_path.directory?) ||
             (home_path.exist? && home_path.directory? && !home_path.symlink?)

    if is_dir
      sync_directory(pattern)
    else
      sync_file(pattern)
    end
  end

  puts "\n=== End Preview ==="
end

def sync_directory(base_pattern)
  repo_dir = REPO_ROOT / base_pattern
  home_dir = CLAUDE_HOME / base_pattern

  if home_dir.exist? && !home_dir.symlink?
    Dir.glob(home_dir / '**' / '*').each do |file|
      next if File.directory?(file)
      relative = Pathname.new(file).relative_path_from(CLAUDE_HOME).to_s
      ensure_in_repo(relative)
    end
  end

  if repo_dir.exist?
    Dir.glob(repo_dir / '**' / '*').each do |file|
      next if File.directory?(file)
      relative = Pathname.new(file).relative_path_from(REPO_ROOT).to_s
      ensure_symlink(relative)
    end
  end
end

def sync_file(pattern)
  ensure_in_repo(pattern)
  ensure_symlink(pattern)
end

def ensure_in_repo(relative_path)
  home_file = CLAUDE_HOME / relative_path
  repo_file = REPO_ROOT / relative_path

  # Detect backwards symlink: repo file should never be a symlink
  if repo_file.symlink?
    if home_file.exist? && !home_file.symlink?
      puts "[FIX]     repo/#{relative_path} is a backwards symlink — would replace with real file from home"
    else
      puts "[REMOVE]  repo/#{relative_path} is a broken backwards symlink — would remove"
    end
    return
  end

  return unless home_file.exist? && !home_file.symlink?

  if repo_file.exist?
    puts "[SKIP]    #{relative_path} — repo file takes precedence over home copy"
  else
    puts "[COPY]    ~/.claude/#{relative_path} -> repo/#{relative_path}"
  end
end

def ensure_symlink(relative_path)
  repo_file = REPO_ROOT / relative_path
  home_file = CLAUDE_HOME / relative_path

  return unless repo_file.exist?

  if home_file.symlink?
    return if home_file.readlink.to_s == repo_file.to_s
    puts "[RELINK]  ~/.claude/#{relative_path} (stale symlink -> #{home_file.readlink})"
  elsif home_file.exist?
    puts "[REPLACE] ~/.claude/#{relative_path} — real file will be replaced with symlink"
  else
    puts "[SYMLINK] ~/.claude/#{relative_path} -> #{repo_file}"
  end
end

main
