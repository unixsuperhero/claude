#!/bin/bash

set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# 1. Check if there are uncommitted files and commit them
if ! git diff --quiet || ! git diff --cached --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
    git add -A
    git commit -m "Auto-commit before sync"
fi

# 2. Rsync ~/.claude to repo root
rsync -avz --exclude='.git' ~/.claude/ "$REPO_ROOT/"
